# MicroCoreOS — Go Environment Configuration

# ── HTTP Server ────────────────────────────────────────────────────────────────
HTTP_PORT=5000

# ── Auth Tool ─────────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=microcoreos-super-secret-change-me-in-production-32chars+
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRE_MINS=60

# ── PostgreSQL DB ─────────────────────────────────────────────────────────────
POSTGRES_DSN=postgres://mcoreos:mcoreos@localhost:5432/mcoreos_dev
# POSTGRES_TOOL_NAME=db          # default: db
# POSTGRES_MIGRATIONS_DIR=domains # default: domains
# POSTGRES_MAX_CONNS=10           # default: 10

# ── Context Tool ──────────────────────────────────────────────────────────────
# AI_CONTEXT_PATH=AI_CONTEXT.md  # default
